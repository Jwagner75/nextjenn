# ─────────────────────────────────────────────────────────────
# AI RECRUITER — INTERVIEW ENGINE
# Environment Variables — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────

# ── VIDEO DELIVERY ────────────────────────────────────────────
# Base URL where your ElevenLabs avatar video files are hosted
# Files expected: intro.mp4, q1.mp4, q2.mp4, q3.mp4, q4.mp4, q5.mp4, outro.mp4
VIDEO_CDN_BASE_URL=https://your-cdn.com/videos

# ── TRANSCRIPTION ─────────────────────────────────────────────
# Whisper model: tiny | base | small | medium | large-v3
# medium recommended — good accuracy, reasonable speed on CPU
WHISPER_MODEL=medium

# ── EMAIL DELIVERY ────────────────────────────────────────────
# Choose your email provider and add the matching API key

# Resend (recommended)
RESEND_API_KEY=your_resend_api_key

# OR SendGrid
# SENDGRID_API_KEY=your_sendgrid_api_key

# OR AWS SES (uses boto3 — set AWS credentials separately)
# AWS_REGION=us-east-1

# From address for all transcript emails
EMAIL_FROM=interviews@yourplatform.com

# ── SERVICE URLS ──────────────────────────────────────────────
# Node.js app URL (Python calls back to this)
NODE_CALLBACK_URL=http://localhost:3000

# Python service port
PYTHON_PORT=5001

# ── NODE SERVER ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development
